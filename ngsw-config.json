{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/favicon.ico", "/index.html", "/manifest.webmanifest", "/*.css", "/*.js"]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/media/**",
          "/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-reads-short-lived",
      "urls": ["/api/**/live-price/**", "/api/**/health/**", "/api/**/drawdown-recovery/latest"],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 50,
        "maxAge": "15s",
        "timeout": "2s"
      }
    },
    {
      "name": "api-reads-stable",
      "urls": [
        "/api/**/currency-pair",
        "/api/**/broker",
        "/api/**/risk-profile",
        "/api/**/economic-event"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 200,
        "maxAge": "1h",
        "timeout": "5s"
      }
    }
  ]
}
